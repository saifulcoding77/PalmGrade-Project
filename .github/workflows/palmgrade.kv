<PalmGradeLayout>:
    orientation: 'vertical'
    spacing: dp(10)
    padding: dp(10)

    Label:
        id: status_label
        text: "MENCARI BUAH..."
        size_hint_y: 0.1
        font_size: '24sp'
        bold: True

    BoxLayout:
        id: camera_container
        size_hint_y: 0.7
        # Pusingkan layout supaya kamera tegak di Vivo V21
        canvas.before:
            PushMatrix
            Rotate:
                angle: -90
                origin: self.center
        canvas.after:
            PopMatrix

    Button:
        id: btn_sah
        text: "SAHKAN MASAK"
        size_hint_y: 0.2
        font_size: '30sp'
        background_color: (0, 1, 0, 1)
        on_press: root.simpan_data()
